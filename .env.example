# ── Google Sheets (backend database) ──────────────────────────────────────────
# Google Sheets spreadsheet ID (from the URL: /d/<SPREADSHEET_ID>/edit)
SPREADSHEET_ID="your_google_spreadsheet_id"

# Google Service Account credentials as a single-line JSON string
# Run: python -c "import json; print(json.dumps(json.load(open('credentials.json'))))"
GOOGLE_CREDENTIALS_JSON='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}'


# ── Google OAuth (Gmail Login) ─────────────────────────────────────────────────
# From Google Cloud Console → Credentials → OAuth 2.0 Client IDs
GOOGLE_OAUTH_CLIENT_ID="your_google_oauth_client_id.apps.googleusercontent.com"
GOOGLE_OAUTH_CLIENT_SECRET="your_google_oauth_client_secret"


# ── LINE OAuth (LINE Login) ────────────────────────────────────────────────────
# From LINE Developers Console → your channel → Basic settings
LINE_CHANNEL_ID="your_line_channel_id"
LINE_CHANNEL_SECRET="your_line_channel_secret"


# ── URLs ───────────────────────────────────────────────────────────────────────
# Where the Flask backend is running (used for OAuth redirect_uri registration)
# Local dev:  http://localhost:5000
# Production: https://your-app.vercel.app
BACKEND_URL="http://localhost:5000"

# Where the React frontend is running (backend redirects user here after OAuth)
# Local dev:  http://localhost:3000
# Production: https://your-app.vercel.app  (same as BACKEND_URL on Vercel)
FRONTEND_URL="http://localhost:3000"

# ── Admin access control ───────────────────────────────────────────────────────
# 用逗號分隔多個值。支援 email（一般登入）或 user_id（特別適合 LINE 登入）。
# 例如 LINE 登入 user_id 常見格式：line_Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_EMAILS="owner@example.com"
ADMIN_USER_IDS=""


# ── Gemini AI (optional) ───────────────────────────────────────────────────────
GEMINI_API_KEY="AIzaSyDL5Sar1-d8nbmlFs36CLK21xlUMfp05uY"


# ── Gmail SMTP（系統自動寄信通知）──────────────────────────────────────────────
# 需先到 https://myaccount.google.com/security 開啟二階段驗證
# 然後到 https://myaccount.google.com/apppasswords 產生「應用程式密碼」（16 碼）
# GMAIL_APP_PASSWORD 只接受應用程式密碼，無法使用 Google 帳戶登入密碼
GMAIL_USER="your_gmail@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"
GMAIL_FROM_NAME="JosieUBOUND"


# ── LINE Messaging API（官方帳號推播通知）───────────────────────────────────────
# 與 LINE Login 分開：需另外在 LINE Developers Console 建立「Messaging API」Channel
# 複製 Channel access token（long-lived）貼到此處
# 使用者必須加入該官方帳號為好友，才能收到 push 訊息
LINE_CHANNEL_ACCESS_TOKEN="your_messaging_api_channel_access_token"
