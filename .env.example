# ── Google Sheets (backend database) ──────────────────────────────────────────
# Google Sheets spreadsheet ID (from the URL: /d/<SPREADSHEET_ID>/edit)
SPREADSHEET_ID="your_spreadsheet_id_here"

# Google Service Account credentials as a single-line JSON string
# Run: python -c "import json; print(json.dumps(json.load(open('credentials.json'))))"
GOOGLE_CREDENTIALS_JSON='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}'


# ── Google OAuth (Gmail Login) ─────────────────────────────────────────────────
# From Google Cloud Console → Credentials → OAuth 2.0 Client IDs
GOOGLE_OAUTH_CLIENT_ID="your_google_oauth_client_id.apps.googleusercontent.com"
GOOGLE_OAUTH_CLIENT_SECRET="your_google_oauth_client_secret"


# ── LINE OAuth (LINE Login) ────────────────────────────────────────────────────
# From LINE Developers Console → your channel → Basic settings
LINE_CHANNEL_ID="your_line_channel_id"
LINE_CHANNEL_SECRET="your_line_channel_secret"


# ── URLs ───────────────────────────────────────────────────────────────────────
# Where the Flask backend is running (used for OAuth redirect_uri registration)
# Local dev:  http://localhost:5000
# Production: https://your-app.vercel.app
BACKEND_URL="http://localhost:5000"

# Where the React frontend is running (backend redirects user here after OAuth)
# Local dev:  http://localhost:3000
# Production: https://your-app.vercel.app  (same as BACKEND_URL on Vercel)
FRONTEND_URL="http://localhost:3000"


# ── Gemini AI (optional) ───────────────────────────────────────────────────────
GEMINI_API_KEY="your_gemini_api_key_here"
